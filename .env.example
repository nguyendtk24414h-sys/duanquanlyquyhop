# Copy this file to .env and fill in your Pinata credentials.
# Do not commit .env into source control.

PINATA_JWT=
# or:
PINATA_API_KEY=
PINATA_API_SECRET=

# Optional values
PORT=3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5500,http://127.0.0.1:5500

# Firebase configuration (kept out of frontend source)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=
