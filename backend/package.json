{
  "name": "pinata-proxy-server",
  "version": "1.0.0",
  "description": "Simple backend proxy for Pinata IPFS metadata uploads.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "npx nodemon --watch server.js --exec node server.js",
    "docker:build": "docker build -t pinata-proxy:latest .",
    "docker:run": "docker run -d -p 3000:3000 --env-file .env --name pinata-proxy pinata-proxy:latest",
    "docker:compose:up": "docker compose up --build -d",
    "docker:compose:down": "docker compose down"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express-rate-limit": "^6.7.0",
    "helmet": "^6.0.1",
    "node-fetch": "^2.6.7",
    "express": "^4.18.2"
  }
}
